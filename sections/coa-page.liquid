
<div
  class="coa-page color-{{ section.settings.color_scheme }}"
  style="
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="coa-page__inner page-width">

    <div class="coa-page__layout">

      {%- comment -%} LEFT COLUMN: header + accordion list {%- endcomment -%}
      <div class="coa-page__content">

        <header class="coa-page__header">
          <h1 class="coa-page__title">
            {%- if section.settings.show_page_title and page.title != blank -%}
              {{ page.title }}
            {%- else -%}
              {{ section.settings.title }}
            {%- endif -%}
          </h1>
          <div class="coa-page__accent-bar"></div>
          {%- if section.settings.subtitle != blank -%}
            <p class="coa-page__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}
        </header>

        {%- if section.settings.show_page_content and page.content != blank -%}
          <div class="coa-page__admin-content rte">{{ page.content }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="coa-page__accordion-list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'coa_entry' -%}

                {%- comment -%} Build the PDF URL — prefer asset file, fall back to external URL {%- endcomment -%}
                {%- assign pdf_href = '' -%}
                {%- if block.settings.pdf_filename != blank -%}
                  {%- assign pdf_href = block.settings.pdf_filename | asset_url -%}
                {%- elsif block.settings.pdf_url != blank -%}
                  {%- assign pdf_href = block.settings.pdf_url -%}
                {%- endif -%}

                <details class="coa-entry" {{ block.shopify_attributes }}>
                  <summary class="coa-entry__summary">
                    <span class="coa-entry__summary-left">
                      {%- if block.settings.badge != blank -%}
                        <span class="coa-entry__badge">{{ block.settings.badge }}</span>
                      {%- endif -%}
                      <span class="coa-entry__title">{{ block.settings.title }}</span>
                    </span>
                    <span class="coa-entry__chevron" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </span>
                  </summary>

                  <div class="coa-entry__body">

                    {%- comment -%} Cannabinoid stat chips {%- endcomment -%}
                    {%- assign has_stats = false -%}
                    {%- if block.settings.total_thc != blank or block.settings.thca != blank or block.settings.cbd != blank or block.settings.d8_thc != blank -%}
                      {%- assign has_stats = true -%}
                    {%- endif -%}

                    {%- if has_stats -%}
                      <div class="coa-entry__stats">
                        {%- if block.settings.total_thc != blank -%}
                          <div class="coa-stat">
                            <span class="coa-stat__label">Total THC</span>
                            <span class="coa-stat__value">{{ block.settings.total_thc }}</span>
                          </div>
                        {%- endif -%}
                        {%- if block.settings.thca != blank -%}
                          <div class="coa-stat">
                            <span class="coa-stat__label">THCa</span>
                            <span class="coa-stat__value">{{ block.settings.thca }}</span>
                          </div>
                        {%- endif -%}
                        {%- if block.settings.cbd != blank -%}
                          <div class="coa-stat">
                            <span class="coa-stat__label">CBD</span>
                            <span class="coa-stat__value">{{ block.settings.cbd }}</span>
                          </div>
                        {%- endif -%}
                        {%- if block.settings.d8_thc != blank -%}
                          <div class="coa-stat">
                            <span class="coa-stat__label">Δ8-THC</span>
                            <span class="coa-stat__value">{{ block.settings.d8_thc }}</span>
                          </div>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if block.settings.description != blank -%}
                      <p class="coa-entry__description">{{ block.settings.description }}</p>
                    {%- endif -%}

                    {%- comment -%} Lab info row {%- endcomment -%}
                    {%- assign has_lab = false -%}
                    {%- if block.settings.lab_name != blank or block.settings.sample_id != blank or block.settings.test_date != blank -%}
                      {%- assign has_lab = true -%}
                    {%- endif -%}
                    {%- if has_lab -%}
                      <div class="coa-entry__lab-info">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v11m0 0H5a2 2 0 0 1-2-2V9m6 5h10a2 2 0 0 0 2-2V9m0 0H3"/></svg>
                        <span>
                          {%- if block.settings.lab_name != blank -%}{{ block.settings.lab_name }}{%- endif -%}
                          {%- if block.settings.sample_id != blank -%} &middot; {{ block.settings.sample_id }}{%- endif -%}
                          {%- if block.settings.test_date != blank -%} &middot; {{ block.settings.test_date }}{%- endif -%}
                        </span>
                      </div>
                    {%- endif -%}

                    {%- if pdf_href != blank -%}
                      <a
                        href="{{ pdf_href }}"
                        class="coa-entry__download-btn"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Download COA for {{ block.settings.title | escape }}"
                      >
                        <span class="coa-entry__download-icon" aria-hidden="true">
                          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="12" y1="18" x2="12" y2="12"/>
                            <line x1="9" y1="15" x2="15" y2="15"/>
                          </svg>
                        </span>
                        Download COA
                      </a>
                    {%- endif -%}

                  </div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <p class="coa-page__lab-note">
            All products tested by <strong>PharmLabs San Diego</strong> &middot; ISO/IEC 17025:2017 Acc. #85368
          </p>

        {%- else -%}
          <p class="coa-page__empty">COAs are being uploaded. Check back soon.</p>
        {%- endif -%}

      </div>

      {%- comment -%} RIGHT COLUMN: image panel {%- endcomment -%}
      {%- if section.settings.image != blank -%}
        <div class="coa-page__image-panel">
          <div class="coa-page__image-wrap">
            {{
              section.settings.image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                class: 'coa-page__image',
                alt: section.settings.image.alt | default: section.settings.title
            }}
            {%- if section.settings.image_caption != blank -%}
              <p class="coa-page__image-caption">{{ section.settings.image_caption }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% stylesheet %}
  @keyframes coaPageFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: none; }
  }

  .coa-page {
    min-height: 50vh;
  }

  .coa-page__inner {
    padding-inline: var(--padding-xl);
    animation: coaPageFadeIn 0.5s ease both;
  }

  /* ── Two-column layout ── */

  .coa-page__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media screen and (min-width: 990px) {
    .coa-page__layout {
      grid-template-columns: 1fr 400px;
      gap: 4.5rem;
      align-items: center;
    }
  }

  /* ── Header ── */

  .coa-page__header {
    margin-bottom: 2.5rem;
  }

  .coa-page__title {
    margin: 0 0 0.5rem;
    color: var(--color-foreground);
  }

  .coa-page__accent-bar {
    width: 60px;
    height: 4px;
    background: var(--color-primary);
    border-radius: 2px;
    margin-bottom: 1rem;
    transition: width 0.4s ease;
  }

  .coa-page__header:hover .coa-page__accent-bar {
    width: 110px;
  }

  .coa-page__subtitle {
    font-size: var(--font-paragraph--size);
    color: rgb(var(--color-foreground-rgb) / 0.65);
    max-width: 560px;
    line-height: 1.65;
    margin: 0;
  }

  .coa-page__admin-content {
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* ── Accordion list ── */

  .coa-page__accordion-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
  }

  .coa-page__lab-note {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-rgb) / 0.45);
    letter-spacing: 0.02em;
  }

  /* ── Individual entry ── */

  .coa-entry {
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
  }

  .coa-entry__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 0.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color 0.2s ease;
  }

  .coa-entry__summary::-webkit-details-marker { display: none; }

  .coa-entry__summary:hover {
    color: var(--color-primary);
  }

  .coa-entry__summary-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }

  .coa-entry__badge {
    display: inline-block;
    padding: 3px 10px;
    background: var(--color-primary);
    color: var(--color-background);
    border-radius: 100px;
    font-size: 0.68rem;
    font-family: var(--font-primary--family);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .coa-entry__title {
    font-family: var(--font-h3--family, var(--font-h2--family));
    font-size: clamp(0.9rem, 1.6vw, 1.05rem);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
    color: inherit;
  }

  .coa-entry__chevron {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: transform 0.3s ease, color 0.2s ease;
    color: rgb(var(--color-foreground-rgb) / 0.4);
  }

  .coa-entry[open] .coa-entry__chevron {
    transform: rotate(180deg);
    color: var(--color-primary);
  }

  .coa-entry__body {
    padding: 0.25rem 0.25rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    animation: coaPageFadeIn 0.22s ease both;
  }

  /* ── Stat chips ── */

  .coa-entry__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .coa-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 0.55rem 1rem;
    background: rgb(var(--color-foreground-rgb) / 0.06);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-radius: 10px;
    min-width: 80px;
  }

  .coa-stat__label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    font-family: var(--font-primary--family);
    font-weight: var(--font-weight-semibold);
    white-space: nowrap;
  }

  .coa-stat__value {
    font-family: var(--font-h2--family, var(--font-primary--family));
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
    line-height: 1;
  }

  /* ── Description & lab info ── */

  .coa-entry__description {
    font-size: var(--font-paragraph--size);
    color: rgb(var(--color-foreground-rgb) / 0.68);
    line-height: 1.65;
    margin: 0;
    max-width: 500px;
  }

  .coa-entry__lab-info {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    color: rgb(var(--color-foreground-rgb) / 0.45);
    letter-spacing: 0.02em;
  }

  .coa-entry__lab-info svg {
    flex-shrink: 0;
    opacity: 0.5;
  }

  /* ── Download button ── */

  .coa-entry__download-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    border: 2px solid var(--color-primary-button-border);
    border-radius: var(--style-border-radius-buttons-primary);
    font-family: var(--font-primary--family);
    font-size: 0.82rem;
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    width: fit-content;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .coa-entry__download-btn:hover {
    background: var(--color-primary-button-hover-background);
    color: var(--color-primary-button-hover-text);
    border-color: var(--color-primary-button-hover-border);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgb(var(--color-primary-rgb) / 0.25);
  }

  .coa-entry__download-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* ── Right image panel ── */

  .coa-page__image-panel {
    position: sticky;
    top: 2rem;
  }

  .coa-page__image-wrap {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .coa-page__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media screen and (min-width: 990px) {
    .coa-page__image {
      aspect-ratio: 3 / 4;
      object-fit: cover;
    }
  }

  .coa-page__image-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.25rem;
    background: linear-gradient(transparent, rgba(0,0,0,0.5));
    color: #fff;
    font-size: var(--font-paragraph-small--size);
    margin: 0;
  }

  .coa-page__empty {
    color: rgb(var(--color-foreground-rgb) / 0.45);
    font-style: italic;
    margin-top: 2rem;
  }

  /* ── Mobile: image first ── */
  @media screen and (max-width: 989px) {
    .coa-page__layout {
      display: flex;
      flex-direction: column-reverse;
    }
    .coa-page__image-panel {
      position: static;
    }
    .coa-page__image-wrap {
      border-radius: 12px;
    }
  }
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .coa-page__image {
      aspect-ratio: 16 / 7;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "COA Page",
  "blocks": [
    {
      "type": "coa_entry",
      "name": "COA Entry",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Product name"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge label",
          "info": "Short pill label next to the title, e.g. \"Hash Hole\" or \"Edible\""
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "header",
          "content": "Cannabinoid Stats"
        },
        {
          "type": "text",
          "id": "total_thc",
          "label": "Total THC",
          "info": "e.g. 45.07%"
        },
        {
          "type": "text",
          "id": "thca",
          "label": "THCa",
          "info": "e.g. 51.32% — leave blank if not applicable"
        },
        {
          "type": "text",
          "id": "cbd",
          "label": "CBD",
          "info": "e.g. 1.64%"
        },
        {
          "type": "text",
          "id": "d8_thc",
          "label": "Δ8-THC",
          "info": "e.g. 3.41% — leave blank if ND"
        },
        {
          "type": "header",
          "content": "Lab Info"
        },
        {
          "type": "text",
          "id": "lab_name",
          "label": "Lab name"
        },
        {
          "type": "text",
          "id": "sample_id",
          "label": "Sample ID"
        },
        {
          "type": "text",
          "id": "test_date",
          "label": "Test date"
        },
        {
          "type": "header",
          "content": "PDF File"
        },
        {
          "type": "text",
          "id": "pdf_filename",
          "label": "PDF filename (from theme assets)",
          "info": "Filename only, e.g. \"126550-dummiez-hash-hole-gas-berry.pdf\". This takes priority over the URL field below."
        },
        {
          "type": "url",
          "id": "pdf_url",
          "label": "PDF URL (external fallback)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Certificates of Analysis"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "All Dummiez products are third-party lab tested. Tap any product below to download its Certificate of Analysis."
    },
    {
      "type": "checkbox",
      "id": "show_page_title",
      "label": "Use Page Title as heading",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_page_content",
      "label": "Show content from Page editor",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right panel image"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Image caption (optional)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "COA Page"
    }
  ]
}
{% endschema %}
