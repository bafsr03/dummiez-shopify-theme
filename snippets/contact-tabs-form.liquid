<style>
  .ct-wrap {
    width: 100%;
    max-width: 640px;
    margin-inline: auto;
  }

  /* Toggle pill bar */
  .ct-toggle {
    display: flex;
    background: #e8e8e8;
    border-radius: 999px;
    padding: 4px;
    gap: 4px;
    width: fit-content;
    margin-inline: auto;
    margin-bottom: 40px;
  }

  .ct-btn {
    padding: 10px 28px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: transparent;
    color: var(--color-foreground, #1a1a1a);
    transition: background 0.2s, color 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }

  .ct-btn[aria-selected="true"] {
    background: var(--color-primary-button-background, #1abcc8);
    color: var(--color-primary-button-text, #ffffff);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  /* Panels */
  .ct-panel { display: none; }
  .ct-panel[aria-hidden="false"] {
    display: block;
    animation: ct-fade 0.25s ease;
  }

  @keyframes ct-fade {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: none; }
  }

  /* Form header */
  .ct-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .ct-heading {
    font-family: var(--font-heading--family);
    font-size: var(--font-size--h2);
    color: var(--color-foreground-heading, #1abcc8);
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0 0 8px;
  }

  .ct-subheading {
    color: var(--color-foreground, #1a1a1a);
    font-size: 1rem;
    opacity: 0.7;
    margin: 0;
  }

  /* Fields */
  .ct-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ct-row {
    display: flex;
    gap: 14px;
    flex-direction: column;
  }

  @media (min-width: 750px) {
    .ct-row { flex-direction: row; }
  }

  .ct-input {
    width: 100%;
    padding: 14px 20px;
    border-radius: var(--style-border-radius-inputs, 32px);
    border: 1px solid var(--color-input-border, #d0d0d0);
    background: var(--color-input-background, #ffffff);
    color: var(--color-input-text, #1a1a1a);
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .ct-input:focus {
    outline: 2px solid var(--color-primary, #1abcc8);
    outline-offset: 2px;
    border-color: var(--color-primary, #1abcc8);
  }

  .ct-textarea {
    resize: vertical;
    min-height: 140px;
  }

  .ct-submit-row {
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .ct-msg {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 0.875rem;
    margin-bottom: 8px;
  }

  .ct-msg--success { background: #e8faf5; color: #0a7c5a; }
  .ct-msg--error   { background: #fde8e8; color: #c0392b; }
</style>

<div class="ct-wrap">
  <div class="ct-toggle" role="tablist">
    <button class="ct-btn" role="tab" aria-selected="true"  data-ct="general"   aria-controls="ct-panel-general">General Inquiries</button>
    <button class="ct-btn" role="tab" aria-selected="false" data-ct="wholesale" aria-controls="ct-panel-wholesale">Wholesale</button>
  </div>

  {% comment %} General Inquiries {% endcomment %}
  <div id="ct-panel-general" class="ct-panel" aria-hidden="false" role="tabpanel">
    <div class="ct-header">
      <h2 class="ct-heading">General Inquiries</h2>
      <p class="ct-subheading">Questions, feedback, or just want to say hi? We&rsquo;d love to hear from you.</p>
    </div>
    {%- form 'contact', id: 'CTFormGeneral', class: 'ct-form' -%}
      <input type="hidden" name="contact[tags]" value="general">
      {%- if form.errors -%}
        <div class="ct-msg ct-msg--error">{{- 'icon-error.svg' | inline_asset_content -}} {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</div>
      {%- endif -%}
      {%- if form.posted_successfully? -%}
        <div class="ct-msg ct-msg--success">{{- 'icon-checkmark.svg' | inline_asset_content -}} {{ 'blocks.contact_form.post_success' | t }}</div>
      {%- endif -%}
      <div class="ct-row">
        <input type="text"  name="contact[name]"  class="ct-input" placeholder="Name"  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
        <input type="email" name="contact[email]" class="ct-input" placeholder="Email" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
      </div>
      <input type="tel"  name="contact[phone]" class="ct-input" placeholder="Phone Number" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
      <textarea name="contact[body]" class="ct-input ct-textarea" placeholder="Message">{{ form.body }}</textarea>
      <div class="ct-submit-row">
        <button type="submit" class="button">SEND MESSAGE</button>
      </div>
    {%- endform -%}
  </div>

  {% comment %} Wholesale Inquiries {% endcomment %}
  <div id="ct-panel-wholesale" class="ct-panel" aria-hidden="true" role="tabpanel">
    <div class="ct-header">
      <h2 class="ct-heading">Wholesale Inquiries</h2>
      <p class="ct-subheading">Interested in carrying Dummiez in your store? Reach out to our wholesale team.</p>
    </div>
    {%- form 'contact', id: 'CTFormWholesale', class: 'ct-form' -%}
      <input type="hidden" name="contact[tags]" value="wholesale">
      {%- if form.errors -%}
        <div class="ct-msg ct-msg--error">{{- 'icon-error.svg' | inline_asset_content -}} {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</div>
      {%- endif -%}
      {%- if form.posted_successfully? -%}
        <div class="ct-msg ct-msg--success">{{- 'icon-checkmark.svg' | inline_asset_content -}} {{ 'blocks.contact_form.post_success' | t }}</div>
      {%- endif -%}
      <div class="ct-row">
        <input type="text"  name="contact[name]"  class="ct-input" placeholder="Name"  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
        <input type="email" name="contact[email]" class="ct-input" placeholder="Email" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
      </div>
      <input type="tel"  name="contact[phone]"    class="ct-input" placeholder="Phone Number" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
      <input type="text" name="contact[business]" class="ct-input" placeholder="Business / Store Name">
      <textarea name="contact[body]" class="ct-input ct-textarea" placeholder="Message">{{ form.body }}</textarea>
      <div class="ct-submit-row">
        <button type="submit" class="button">SEND WHOLESALE INQUIRY</button>
      </div>
    {%- endform -%}
  </div>
</div>

<script>
(function() {
  var wrap = document.currentScript.previousElementSibling;
  while (wrap && !wrap.classList.contains('ct-wrap')) {
    wrap = wrap.previousElementSibling;
  }
  if (!wrap) return;

  wrap.querySelectorAll('.ct-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.dataset.ct;
      wrap.querySelectorAll('.ct-btn').forEach(function(b) {
        var active = b === btn;
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      wrap.querySelectorAll('.ct-panel').forEach(function(panel) {
        var active = panel.id === 'ct-panel-' + tab;
        panel.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
    });
  });
})();
</script>
