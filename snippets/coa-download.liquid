{%- doc -%}
  Renders a branded "Download COA" button for a product if the
  `custom.coa_pdf` metafield is set. Upload the COA PDF to Shopify Admin →
  Content → Files, then paste the URL into the product's metafield.

  Setup (one-time, in Shopify Admin):
    Settings → Custom data → Products → Add definition
    Namespace: custom  |  Key: coa_pdf  |  Type: URL  |  Name: COA PDF

  @param {object} product - The product object
  @example
  {% render 'coa-download', product: product %}
{%- enddoc -%}

{%- assign coa_url = product.metafields.custom.coa_pdf -%}
{%- if coa_url != blank -%}
  <div class="coa-download">
    <span class="coa-download__label">Certificate of Analysis</span>
    <a
      href="{{ coa_url }}"
      class="coa-download__button"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Download Certificate of Analysis for {{ product.title | escape }}"
    >
      <span class="coa-download__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="12" y1="18" x2="12" y2="12"/>
          <line x1="9" y1="15" x2="15" y2="15"/>
        </svg>
      </span>
      <span class="coa-download__text">Download COA</span>
    </a>
  </div>

  <style>
    .coa-download {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-block: 12px;
      animation: coaFadeIn 0.4s ease both;
    }

    @keyframes coaFadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: none; }
    }

    .coa-download__label {
      font-size: var(--font-paragraph-small--size, 0.8rem);
      font-weight: var(--font-weight-semibold, 600);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgb(var(--color-foreground-rgb) / 0.6);
    }

    .coa-download__button {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: #000;
      color: #fef824;
      border: 2px solid #fef824;
      border-radius: var(--style-border-radius-buttons, 4px);
      font-family: var(--font-primary--family);
      font-size: var(--font-paragraph--size, 0.95rem);
      font-weight: var(--font-weight-semibold, 600);
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
      width: fit-content;
    }

    .coa-download__button:hover {
      background: #fef824;
      color: #000;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(254, 248, 36, 0.35);
    }

    .coa-download__button:active {
      transform: translateY(0);
      box-shadow: none;
    }

    .coa-download__icon {
      display: flex;
      align-items: center;
      flex-shrink: 0;
      transition: transform 0.3s ease;
    }

    .coa-download__button:hover .coa-download__icon {
      animation: coaPulse 0.5s ease;
    }

    @keyframes coaPulse {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.25); }
      100% { transform: scale(1); }
    }
  </style>
{%- endif -%}
